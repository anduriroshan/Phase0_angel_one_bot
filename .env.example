# Angel One SmartAPI Credentials
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

ANGEL_CLIENT_ID="YOUR_CLIENT_ID"
ANGEL_PIN="YOUR_4_DIGIT_PIN"
ANGEL_API_KEY="YOUR_API_KEY"
ANGEL_TOTP_SECRET="YOUR_TOTP_SECRET"

# Circuit Breaker Configuration
# Maximum loss (in INR) before the circuit breaker triggers a full exit.
CIRCUIT_BREAKER_MAX_LOSS=10000

# QuestDB Configuration
QUESTDB_ILP_ADDR="localhost:9000"

# Instrument tokens to subscribe (comma-separated)
# These are Angel One instrument tokens for NSE_FO options.
# Example: nearest ATM Nifty weekly CE and PE
# Instrument tokens to subscribe (comma-separated)
# NIFTY 50 (26009) and NIFTY BANK (26000) are NSE Cash Market (CM) index tokens.
# SUBSCRIBE_EXCHANGE: 1=NSE_CM, 2=NSE_FO, 3=BSE_CM, 4=BSE_FO, 5=MCX_FO
# Use exchange_type=1 for index tokens (NIFTY, BANKNIFTY spot).
# Use exchange_type=2 for F&O contracts (futures/options instrument tokens).
SUBSCRIBE_TOKENS="26009,26000"
SUBSCRIBE_EXCHANGE=1
